generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String            @id @default(cuid())
  name       String            @default("Admin")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  accounts   PlatformAccount[]
  posts      Post[]
  keywords   Keyword[]
  autoRules  AutoRule[]
}

model PlatformAccount {
  id                String            @id @default(cuid())
  userId            String
  platform          String
  platformUserId    String
  platformUsername  String
  profilePictureUrl String?
  accessToken       String
  tokenType         String
  tokenExpiresAt    DateTime
  refreshToken      String?
  isActive          Boolean           @default(true)
  lastSyncedAt      DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts             Post[]
  metricsSnapshots  MetricsSnapshot[]
  keywordMatches    KeywordMatch[]
  automationLogs    AutomationLog[]

  @@unique([platform, platformUserId])
}

model Post {
  id              String         @id @default(cuid())
  userId          String
  accountId       String
  contentType     String
  title           String?
  textContent     String?
  htmlContent     String?
  excerpt         String?
  mediaUrls       String?
  featuredImageUrl String?
  categories      String?
  tags            String?
  topicTag        String?
  status          String
  scheduledAt     DateTime?
  publishedAt     DateTime?
  errorMessage    String?
  platformPostId  String?
  platformUrl     String?
  replyToPostId   String?
  sourceMatchId   String?
  isAutoGenerated Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metrics         PostMetrics[]
  sourceMatch     KeywordMatch?   @relation("KeywordMatchGeneratedPosts", fields: [sourceMatchId], references: [id], onDelete: SetNull)
}

model PostMetrics {
  id         String   @id @default(cuid())
  postId      String
  views       Int      @default(0)
  likes       Int      @default(0)
  replies     Int      @default(0)
  reposts     Int      @default(0)
  quotes      Int      @default(0)
  shares      Int      @default(0)
  capturedAt  DateTime @default(now())
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model MetricsSnapshot {
  id            String          @id @default(cuid())
  accountId      String
  followerCount  Int             @default(0)
  totalViews     Int             @default(0)
  totalLikes     Int             @default(0)
  totalReplies   Int             @default(0)
  totalReposts   Int             @default(0)
  totalQuotes    Int             @default(0)
  countryData    String?
  cityData       String?
  ageData        String?
  genderData     String?
  capturedAt     DateTime        @default(now())
  account        PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Keyword {
  id         String         @id @default(cuid())
  userId     String
  keyword    String
  isActive   Boolean        @default(true)
  matchMode  String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches    KeywordMatch[]
}

model KeywordMatch {
  id             String           @id @default(cuid())
  keywordId      String
  accountId      String?
  platformPostId String
  sourcePostId   String?
  authorUsername String
  authorId       String?
  postText       String
  postUrl        String?
  matchedAt      DateTime         @default(now())
  actionTaken    String?
  actionPostId   String?
  keyword        Keyword          @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  account        PlatformAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  generatedPosts Post[]           @relation("KeywordMatchGeneratedPosts")
  logs           AutomationLog[]

  @@unique([keywordId, platformPostId])
}

model AutoRule {
  id               String   @id @default(cuid())
  userId           String
  name             String
  isActive         Boolean  @default(true)
  triggerType      String
  triggerConfig    String
  actionType       String
  actionConfig     String
  dailyLimit       Int      @default(50)
  delayMinSeconds  Int      @default(30)
  delayMaxSeconds  Int      @default(300)
  executionCount   Int      @default(0)
  lastExecutedAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs             AutomationLog[]
}

model AutomationLog {
  id            String       @id @default(cuid())
  ruleId        String?
  matchId       String?
  accountId     String?
  postId        String?
  actionType    String
  status        String
  detail        String?
  executedAt    DateTime     @default(now())
  rule          AutoRule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  match         KeywordMatch? @relation(fields: [matchId], references: [id], onDelete: SetNull)
  account       PlatformAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model AppSettings {
  id                    String   @id @default(cuid())
  automationPaused      Boolean  @default(false)
  keywordScanPaused     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
